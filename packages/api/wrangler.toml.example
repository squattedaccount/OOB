name = "oob-api"
main = "src/index.ts"
compatibility_date = "2024-11-15"

[vars]
# Protocol fee — OOB takes this on every order, enforced server-side
# IMPORTANT: Replace with your actual treasury address
PROTOCOL_FEE_RECIPIENT = "0xYOUR_TREASURY_ADDRESS_HERE"
PROTOCOL_FEE_BPS = "50"  # 0.5% protocol fee

# Rate limiting defaults (per minute)
RATE_LIMIT_PUBLIC_READS = "60"
RATE_LIMIT_PUBLIC_WRITES = "30"
RATE_LIMIT_REGISTERED_READS = "300"
RATE_LIMIT_REGISTERED_WRITES = "60"

# Secrets (set via wrangler secret put — NEVER put these in [vars]):
# - DATABASE_URL              (Neon Postgres connection string)
# - POOL_DATABASE_URL         (optional Neon pooled connection string for request traffic)
# - API_ADMIN_TOKEN           (for admin endpoints, optional)
# - SESSION_SECRET            (required for auth/subscription dashboard routes)
# - API_KEYS                  (comma-separated registered API keys, e.g. "key1,key2")
# - SUBSCRIPTION_TREASURY_ADDRESS
# - SUBSCRIPTION_PAYMENT_TOKEN_ADDRESS
# - SUBSCRIPTION_PAYMENT_CHAIN_ID
# - SUBSCRIPTION_MIN_CONFIRMATIONS
# - RPC_URL_BASE              (required for onchain subscription payment verification on Base)
# - UPSTASH_REDIS_REST_URL    (Upstash Redis REST endpoint)
# - UPSTASH_REDIS_REST_TOKEN  (Upstash Redis REST token)
#
# Example:
#   wrangler secret put API_KEYS
#   wrangler secret put DATABASE_URL
#   wrangler secret put SESSION_SECRET
#   wrangler secret put SUBSCRIPTION_TREASURY_ADDRESS
#   wrangler secret put SUBSCRIPTION_PAYMENT_TOKEN_ADDRESS
#   wrangler secret put SUBSCRIPTION_PAYMENT_CHAIN_ID
#   wrangler secret put SUBSCRIPTION_MIN_CONFIRMATIONS
#   wrangler secret put RPC_URL_BASE
#   wrangler secret put UPSTASH_REDIS_REST_URL
#   wrangler secret put UPSTASH_REDIS_REST_TOKEN

# KV for rate limiting counters
# Create with: wrangler kv:namespace create "OOB_RATE_LIMIT"
[[kv_namespaces]]
binding = "OOB_RATE_LIMIT"
id = "YOUR_KV_NAMESPACE_ID"

# Durable Objects for WebSocket streams
[durable_objects]
bindings = [
  { name = "ORDER_STREAM", class_name = "OrderStreamDO" }
]

[[migrations]]
tag = "v1"
new_sqlite_classes = ["OrderStreamDO"]
